import 'package:blood_bridge/constants.dart';
import 'package:blood_bridge/l10n/app_localizations.dart';
import 'package:blood_bridge/core/services/text_style_helper.dart';
import 'package:blood_bridge/core/utiles/app_colors.dart';
import 'package:blood_bridge/core/widgets/blood_type_icon.dart';
import 'package:blood_bridge/core/widgets/custom_textfield.dart';
import 'package:blood_bridge/features/user_information/presentation/cubit/info_cubit.dart';
import 'package:flutter/cupertino.dart';
import 'package:flutter/material.dart';
import 'package:flutter_bloc/flutter_bloc.dart';

class ThirdInfoScreen extends StatelessWidget {
  ThirdInfoScreen({
    super.key,
    required this.height,
    required this.weightController,
    required this.width,
    required this.medicalController,
    required this.cubit,
  });

  final double height;
  final TextEditingController weightController;
  final double width;
  final TextEditingController medicalController;
  final InfoCubit cubit;
  @override
  Widget build(BuildContext context) {
    String? selectedBloodType = cubit.bloodType;

    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Text("blood type *", style: TextStyleHelper.small(context)),
        SizedBox(height: height * 0.01),
        Wrap(
          spacing: 10,
          runSpacing: 10,
          children: bloodTypes
              .map(
                (e) => GestureDetector(
                  onTap: () {
                    selectedBloodType = e;
                    cubit.setBloodType(e);
                  },
                  child: BlocBuilder<InfoCubit, InfoState>(
                    builder: (context, state) {
                      return BloodTypeIcon(
                        bloodType: e,
                        height: height,
                        width: width,
                        isSelected: selectedBloodType == e,
                      );
                    },
                  ),
                ),
              )
              .toList(),
        ),
        SizedBox(height: height * 0.04),
        Text("weight *", style: TextStyleHelper.small(context)),
        SizedBox(height: height * 0.01),
        CustomTextfield(
          prefixIcon: Icon(CupertinoIcons.bag),
          text: AppLocalizations.of(context)!.enterWeight,
          controller: weightController,
          validator: cubit.weightValidator,
        ),
        SizedBox(height: height * 0.04),
        Text(
          "Medical Conditions (Optional)",
          style: TextStyleHelper.small(context),
        ),
        SizedBox(height: height * 0.01),
        TextField(
          maxLines: 5,
          controller: medicalController,
          style: TextStyle(color: AppColors.textMuted),
          decoration: InputDecoration(
            hintText: AppLocalizations.of(context)!.enterYourMedicalConditions,
            filled: true,
            fillColor: AppColors.accent,
            border: OutlineInputBorder(
              borderRadius: BorderRadius.circular(10),
              borderSide: BorderSide(color: AppColors.textMuted),
            ),
            focusedBorder: OutlineInputBorder(
              borderRadius: BorderRadius.circular(10),
              borderSide: BorderSide(color: AppColors.primary, width: 2.0),
            ),
          ),
        ),
      ],
    );
  }
}
